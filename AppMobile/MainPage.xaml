<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMobile.MainPage">
    <VerticalStackLayout
               Padding="30,0"
                Spacing="25">
        <StackLayout Padding="10,0,0,0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
            <Image Source="https://i.postimg.cc/rdjHDk27/user.png" 
           WidthRequest="50" 
           HeightRequest="50" 
           HorizontalOptions="Center" 
           VerticalOptions="Center" 
           Aspect="AspectFit" />
        </StackLayout>
        <StackLayout Padding="30,20,0,0">
            <Label Text="App Mobile" TextColor="Green" />
        </StackLayout>
        <Grid RowDefinitions="Auto, Auto" 
                      ColumnDefinitions="Auto, *"
                      RowSpacing="10" 
                      ColumnSpacing="10"
                      Padding="15">

            <Label Text="Email:"
                       Grid.Row="0" Grid.Column="0"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
            <Entry x:Name="txtEmail" Grid.Row="0" Grid.Column="1" Placeholder="Digite seu email" HorizontalOptions="Start" VerticalOptions="StartAndExpand" HeightRequest="40" WidthRequest="300" FontSize="Small" />

            <Label Text="Senha:" 
                       Grid.Row="1" Grid.Column="0"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
            <Entry x:Name="txtSenha" Grid.Row="1" Grid.Column="1" Placeholder="Digite a senha" HorizontalOptions="Start" VerticalOptions="StartAndExpand" HeightRequest="40" WidthRequest="300" FontSize="Small" IsPassword="True" />
        </Grid>
        <StackLayout Padding="70,50,50,0">
            <Button HorizontalOptions="FillAndExpand" VerticalOptions="StartAndExpand" HeightRequest="40" Text="Login" Clicked="btnLogin_Clicked" FontSize="Small"/>
        </StackLayout>
        <StackLayout Padding="70,20,50,0">
            <Button Text="Esqueci minha senha" TextColor="Blue" BackgroundColor="White" Clicked="btnEsqueci_Clicked"/>
            <Label x:Name="label1"/>
            <Button Text="Cadastrar-se" TextColor="Blue"  BackgroundColor="White" Clicked="btnCadastrar_Clicked"/>
            <Label x:Name="label2"/>
        </StackLayout>
    </VerticalStackLayout>
</ContentPage>
