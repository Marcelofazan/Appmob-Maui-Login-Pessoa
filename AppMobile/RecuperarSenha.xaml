<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMobile.RecuperarSenha"
             Title="RecuperarSenha">
    <VerticalStackLayout
                Padding="30,0"
                Spacing="25">
        <StackLayout Padding="10,0,0,0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
            <Image Source="https://i.postimg.cc/rdjHDk27/user.png" 
           WidthRequest="50" 
           HeightRequest="50" 
           HorizontalOptions="Center" 
           VerticalOptions="Center" 
           Aspect="AspectFit" />
        </StackLayout>
        <StackLayout Padding="30,20,0,0">
            <Label Text="Esqueceu sua senha, envie as informações de Login para seu email" TextColor="Green" />
        </StackLayout>
        <Grid RowDefinitions="Auto" 
                      ColumnDefinitions="Auto, *"
                      RowSpacing="10" 
                      ColumnSpacing="10"
                      Padding="15">

            <Label Text="Email:"
                       Grid.Row="0" Grid.Column="0"
                       VerticalOptions="Center" />
            <Entry x:Name="txtEmail" Grid.Row="0" Grid.Column="1" Placeholder="Informe seu email" HorizontalOptions="Start" VerticalOptions="StartAndExpand" HeightRequest="50" WidthRequest="300" FontSize="Small"/>
        </Grid>
        <StackLayout Padding="10,50,10,0">
            <Button HorizontalOptions="FillAndExpand" VerticalOptions="StartAndExpand" HeightRequest="40" Text="Lembrar-Me" Clicked="btnLembrar_Clicked" FontSize="Small"/>
        </StackLayout>
        <StackLayout Padding="10,50,10,0">
            <Button HorizontalOptions="FillAndExpand" VerticalOptions="StartAndExpand" HeightRequest="40" Text="Voltar" Clicked="btnVoltar_Clicked" FontSize="Small"/>
        </StackLayout>
    </VerticalStackLayout>
</ContentPage>