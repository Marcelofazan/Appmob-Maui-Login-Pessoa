<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMobile.EnvioEmail"
             Title="EnvioEmail">
    <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
        <StackLayout Padding="10,0,0,0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
            <Image Source="https://i.postimg.cc/rdjHDk27/user.png" 
           WidthRequest="50" 
           HeightRequest="50" 
           HorizontalOptions="Center" 
           VerticalOptions="Center" 
           Aspect="AspectFit" />
        </StackLayout>
        <StackLayout Padding="70,80,50,0">
            <Label Text="{Binding Email}" FontSize="Medium" FontAttributes="Bold" />
            <Label Text="Foi enviado um email. Verifique sua caixa de entrada!!!" HorizontalOptions="FillAndExpand" />
        </StackLayout>

        <StackLayout Padding="10,50,10,0">
            <Button HorizontalOptions="FillAndExpand" VerticalOptions="StartAndExpand" HeightRequest="40" Text="Login" Clicked="btnLogin_Clicked" FontSize="Small"/>
        </StackLayout>
    </VerticalStackLayout>
</ContentPage>