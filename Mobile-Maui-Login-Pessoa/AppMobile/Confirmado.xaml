<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMobile.Confirmado"
             Title="Confirmado">
    <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
        <StackLayout Padding="10,0,0,0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
            <Image Source="https://i.postimg.cc/rdjHDk27/user.png" 
           WidthRequest="50" 
           HeightRequest="50" 
           HorizontalOptions="Center" 
           VerticalOptions="Center" 
           Aspect="AspectFit" />
        </StackLayout>
        <StackLayout Padding="70,100,50,0">
            <Label Text="Nome:" HorizontalOptions="FillAndExpand" />
            <Label Text="{Binding RazaoSocial}" FontSize="Medium" FontAttributes="Bold" />
        </StackLayout>
        <StackLayout Padding="70,80,50,0">
            <Label Text="Usuário Cadastrado com sucesso!!!" HorizontalOptions="FillAndExpand" />
        </StackLayout>
        <StackLayout Padding="10,50,10,0">
            <Button HorizontalOptions="FillAndExpand" VerticalOptions="StartAndExpand" HeightRequest="40" Text="Voltar" Clicked="btnVoltar_Clicked" FontSize="Small"/>
        </StackLayout>
    </VerticalStackLayout>
</ContentPage>